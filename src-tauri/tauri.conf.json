{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NTS-811s1 Desktop App",
  "version": "1.0.0",
  "identifier": "nts.811s1.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NTS-811s1 Desktop App",
        "width": 1475,
        "height": 800,
        "minWidth": 1475,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#1e1e1e",
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/mission_schedule_config.xml"]
  }
}
